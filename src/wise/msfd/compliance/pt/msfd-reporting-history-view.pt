<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en"
  xmlns:tal="http://xml.zope.org/namespaces/tal"
  xmlns:metal="http://xml.zope.org/namespaces/metal"
  xmlns:i18n="http://xml.zope.org/namespaces/i18n" lang="en" metal:use-macro="context/main_template/macros/master" i18n:domain="eea">

  <metal:block fill-slot="main">

    <div id="wise-search-form" class="full-width-marker">

      <div id="wise-search-form-top">
        <metal:tabs metal:use-macro="context/wise-macros/macros/tabs"></metal:tabs>
      </div>

      <div class="start-page-content left-side-formZ full-width-marker">

        <h3 class="report-title">Edit MSFD reporting history</h3>

        <div id="edit-msfd-history" class="modal fade" tabindex="-1" role="dialog">
          <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
              <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                  <span aria-hidden="true">&times;</span>
                </button>
                <h3 class="modal-title">Edit row</h3>
              </div>

              <div class="modal-body">
                <form id="msfd-history-form" method="POST" tal:attributes="action context/absolute_url">
                  <div class="form-group">
                    <label>Row number:</label>
                    <textarea tal:content="python: len(view.msfd_rep_history_data) + 1" tal:attributes="max-rows python: len(view.msfd_rep_history_data) + 1" id="Row" name="Row" class="form-control disabled">
                    </textarea>
                  </div>
                  <tal:rep tal:repeat="header python: view.msfd_rep_history_headers()">
                    <div class="form-group">
                      <label tal:content="header">Label:</label>
                      <textarea class="form-control editable" tal:attributes="id header; name header">
                      </textarea>
                    </div>
                  </tal:rep>
                  <input class="submitRecomm btn btn-primary btn-s" type="submit" value="Save" name="add-msfd-data"/>
                </form>
              </div>
            </div>
          </div>
        </div>

        <div tal:condition="python: view.can_view_assessment_data()">
          <a class="btn btn-s btn-primary" data-toggle="modal" data-target="#edit-msfd-history">
              Add new data
          </a>
          <a class="btn btn-s btn-primary" tal:attributes="href python: context.absolute_url() + '/@@msfd-reporting-history?download-excel'" target="_blank">
              Download as excel
          </a>
          <a class="btn btn-s btn-danger" tal:condition="view/can_manage" tal:attributes="href python: context.absolute_url() + '/edit'" target="_blank">
              Upload new excel file
          </a>
        </div>

        <div class="overflow-table sticky-overflow-header hidden-fixed-table">
          <div class="inner" style="overflow: auto; margin-top: 1em;">
            <table id="msfd-history-edit-table" class="table table-listing table-report table-striped table-bordered">
              <thead>
                <tr class="sticky-row">
                  <th></th>
                  <th>Row</th>
                  <tal:rep tal:repeat="value python:view.msfd_rep_history_headers()">
                    <th tal:attributes="style python: 'min-width: {}'.format(view.column_widths.get(value, ''))" tal:content="value">Table header</th>
                  </tal:rep>
                </tr>
              </thead>
              <tbody style="word-break: keep-all;">
                <tr tal:repeat="row python: view.msfd_rep_history_data">
                  <td class="edit-row-button">
                    <a class="btn btn-sm btn-primary" data-toggle="modal" data-target="#edit-msfd-history">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pencil-square" viewBox="0 0 16 16">
                        <path d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z"/>
                        <path fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5z"/>
                      </svg>
                    </a>
                  </td>
                  <td tal:content="python: row[0] + 1">1</td>
                  <tal:rep tal:repeat="header python: view.msfd_rep_history_columns">
                    <tal:def tal:define="value python: getattr(row[1], header)">
                      <td tal:condition="python: not str(value).startswith('http')" tal:content="value">Value here</td>
                      <td tal:condition="python: str(value).startswith('http')">
                        <a tal:attributes="href value" tal:content="value">url here</a>
                      </td>
                    </tal:def>
                  </tal:rep>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </metal:block>

</html>
