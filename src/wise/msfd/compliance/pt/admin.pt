<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en"
  xmlns:tal="http://xml.zope.org/namespaces/tal"
  xmlns:metal="http://xml.zope.org/namespaces/metal"
  xmlns:i18n="http://xml.zope.org/namespaces/i18n" lang="en" metal:use-macro="context/main_template/macros/master" i18n:domain="eea">

  <metal:block fill-slot="main">

    <div id="layout-contents" tal:define="text context/text | nothing">
      <div id="wise-search-form" class="full-width-marker">
        <div id="wise-search-form-topZ">
          <metal:tabs metal:use-macro="context/wise-macros/macros/tabs"></metal:tabs>
        </div>

        <div class="start-page-content left-side-formZ">

          <h1>Management page</h1>

          <div class="nda-link">
            <a href="./">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-left" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8"/>
              </svg>
              Go to the Compliance Assessment Module
            </a>
          </div>

          <div class="form-group">
            <a class="btn btn-primary btn-small btn-success" tal:attributes="href string:${view/_compliance_folder/absolute_url}/@@compliance-users" target="_blank">
              <i class="glyphicon glyphicon-user"></i>
              Compliance Users
            </a>

            <a class="btn btn-primary btn-small btn-success" tal:attributes="href string:${view/_compliance_folder/absolute_url}/national-descriptors-assessments/@@translations-overview" target="_blank">
              <i class="glyphicon glyphicon-globe"></i>Translations overview</a>

            <a class="btn btn-primary btn-small btn-success" tal:attributes="href string:${view/_compliance_folder/absolute_url}/national-descriptors-assessments/@@edit-assessors" target="_blank">
              <i class="glyphicon glyphicon-pencil"></i>
              Edit assessors
            </a>

            <a class="btn btn-primary btn-small btn-success" tal:attributes="href string:${view/_compliance_folder/absolute_url}/national-descriptors-assessments/@@admin-scoring" target="_blank">
              <i class="glyphicon glyphicon-modal-window"></i>
              Scoring operations
            </a>

            <a class="btn btn-primary btn-small btn-success" tal:attributes="href string:${view/_compliance_folder/absolute_url}/national-descriptors-assessments/@@admin-scoring?export-scores=1" target="_blank">
              <i class="glyphicon glyphicon-export"></i>
              Export Compliance Data
            </a>

            <a class="btn btn-primary btn-small btn-success" tal:attributes="href string:${view/_compliance_folder/absolute_url}/msfd-reporting-history" target="_blank">
              <i class="glyphicon glyphicon-file"></i>
              Edit MSFD Reporting History data
            </a>

            <a class="btn btn-primary btn-small btn-success" tal:attributes="href string:${view/_compliance_folder/absolute_url}/@@recommendations" target="_blank">
              <i class="glyphicon glyphicon-book"></i>
              Edit recommendations
            </a>

          </div>

        </div>
      </div>
    </div>

  </metal:block>
</html>
