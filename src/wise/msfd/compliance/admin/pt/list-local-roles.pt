<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en"
  xmlns:tal="http://xml.zope.org/namespaces/tal"
  xmlns:metal="http://xml.zope.org/namespaces/metal"
  xmlns:i18n="http://xml.zope.org/namespaces/i18n" lang="en" metal:use-macro="context/main_template/macros/master" i18n:domain="eea">

  <metal:block fill-slot="main">

    <div id="layout-contents">
      <div class="start-page-content">

        <h1>Local Roles</h1>

        <p tal:define="rows view/rows">
          Total entries: <span tal:content="python:len(rows)">0</span>
        </p>

        <table class="table table-striped table-condensed">
          <thead>
            <tr>
              <th>URL</th>
              <th>Principal</th>
              <th>Email</th>
              <th>Roles</th>
            </tr>
          </thead>
          <tbody>
            <tr tal:repeat="row view/rows">
              <td tal:content="row/url">/path/to/object</td>
              <td tal:content="row/principal">principal-name</td>
              <td tal:content="row/email">-</td>
              <td tal:content="row/roles">Role1, Role2</td>
            </tr>
          </tbody>
        </table>

      </div>
    </div>

  </metal:block>
</html>