<div id="wise-compliance-form" class="full-width-marker" tal:define="can_comment view/can_comment; plone nocall:context/@@plone" tal:attributes="id view/form_id | string:wise-compliance-form">

  <div id="wise-compliance-form-top" tal:attributes="id view/form_id_top | string:wise-compliance-form-top">
    <metal:tabs metal:use-macro="context/wise-macros/macros/tabs"></metal:tabs>
  </div>

  <div class="wise-search-form-container" tal:attributes="id view/form_container_class | string:wise-search-form-container">

    <div class="left-side-formZ nat-edit-form">

      <div class="crt-def">
        <button type="button" class="btn btn-primary btn-lg" data-toggle="modal" data-target="#assessment-help">
          Criteria definition
        </button>
      </div>
      <h2 tal:content="structure view/title" class="report-title">Title here</h2>
      <!--<h4 class="process-phase-title">-->
      <!--Current phase: <span tal:content="python: view.current_phase[1]">Adequacy</span>-->
      <!--</h4>-->

      <div id="report-data-navigation" tal:condition="python: options.get('show_navigation') != False and view.can_view_assessment_data()">
        <div class="back-to-descr">
          <a href="./">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-left" viewBox="0 0 16 16">
              <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8"/>
            </svg>
            Back to descriptor assessment overview
          </a>
        </div>

        <div id="assessment-edit-infobox"></div>
        <div metal:use-macro="context/wise-macros/macros/reg-desc-report-nav"></div>
      </div>

      <div id="comp-national-descriptor" tal:define="view nocall:view">

        <div tal:replace="structure view/help" tal:on-error="string:Error in help">Subform help here</div>

        <metal:form use-macro="view/context/@@ploneform-macros/titlelessform">

          <metal:fields fill-slot="fields">
            <tal:rep tal:repeat='subform view/subforms'>

              <div class="subform" tal:define="disabled python:subform._disabled and ' disabled' or ''" tal:attributes="class string:subform $disabled">

                <div class="body">
                  <div class="left">
                    <div class="subform-title">
                      <span tal:content="subform/title" class="question-title">Question here</span>
                      <span style="float:right;" tal:define="last_change python: view.format_last_change(subform._last_update)" class="pat-tooltip" tal:attributes="title python: last_change;">
                        <span tal:content="string:Last change">Last change</span>
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-calendar-check" viewBox="0 0 16 16">
                          <path d="M10.854 7.146a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708 0l-1.5-1.5a.5.5 0 1 1 .708-.708L7.5 9.793l2.646-2.647a.5.5 0 0 1 .708 0"/>
                          <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5M1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4z"/>
                        </svg>
                      </span>
                    </div>

                    <div class="fields-container">
                      <div tal:repeat="fieldname subform/fields" class="fields-container-row">
                        <tal:def define="widget python: view.widgets[fieldname]">

                          <div class="field" tal:define="error widget/error;
                            hidden python:widget.mode == 'hidden';
                            element nocall: widget/field/_element | nothing;
                            " tal:attributes="class python:'field' + (error and ' error' or '')">

                            <span class="fieldRequired" title="Required" tal:condition="python:widget.required and not hidden" i18n:translate="label_required" i18n:attributes="title title_required;">
                              (Required)
                            </span>

                            <div class="widget">
                              <div>
                                <label for="" tal:condition="not:hidden" class="pat-tooltip" tal:attributes="for widget/id;
                                  titleZ python: element and element.title or '';
                                  title python: element and element.definition or ''">
                                  <span i18n:translate="" tal:content="widget/label">label</span>
                                  <!-- <span tal:condition="element" class="glyphicon glyphicon-question-sign"></span> -->
                                </label>
                              </div>
                              <div class="assessment-form-input">
                                <input type="text" tal:replace="structure widget/render" />
                              </div>
                            </div>

                            <div class="formHelp" tal:define="description widget/field/description" i18n:translate="" tal:content="description" tal:condition="python:description and not hidden">
                              field description
                            </div>

                            <div tal:condition="error" tal:content="structure error/render">
                              Error
                            </div>
                          </div>

                        </tal:def>
                      </div>
                    </div>
                  </div>

                  <div class="right discussion disc-tl" tal:define="question_id subform/_question/id | string:summary">
                    <div class="comments-header">
                      <i class="comm-hide glyphicon glyphicon-plus-sign" title="Show all comments"></i>
                    </div>
                    <div class="comments" tal:attributes="data-question-id question_id; data-thread-id string:tl"></div>
                    <div tal:condition="python: can_comment" class="textline">
                      <textarea name="comment-text" placeholder="Write a comment..."></textarea>
                      <button class="btn btn-primary">Post</button>
                    </div>
                  </div>
                </div>
              </div>
            </tal:rep>
          </metal:fields>

          <metal:slot fill-slot="actions">
            <div tal:condition="python: not(view.read_only_access)" class="form-right-side">
              <metal:block use-macro="context/@@ploneform-macros/actions" />
            </div>
          </metal:slot>

        </metal:form>
      </div>
    </div>
  </div>
</div>
