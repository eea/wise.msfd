<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en"
  xmlns:tal="http://xml.zope.org/namespaces/tal"
  xmlns:metal="http://xml.zope.org/namespaces/metal"
  xmlns:i18n="http://xml.zope.org/namespaces/i18n" lang="en" metal:use-macro="context/main_template/macros/master" i18n:domain="eea">

  <metal:block fill-slot="main">

    <div id="layout-contents" tal:define="text context/text | nothing">
      <div id="wise-search-form" class="full-width-marker">
        <div id="wise-search-form-topZ">
          <metal:tabs metal:use-macro="context/wise-macros/macros/tabs"></metal:tabs>
        </div>

        <div class="start-page-content left-side-formZ">

          <h1>Descriptor assessments - regional overview: <span tal:content="context/title"></span>
          </h1>

          <div class="nda-link">
            <a href="./../">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-left" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8"/>
              </svg>
              Go to all Regional Descriptor Assessments
            </a>
          </div>

          <div class="process-state-phase-form" tal:condition="view/can_manage">
            <form class="process-state" method="GET" tal:attributes="action python: context.absolute_url() + '/content_status_modify'">
              <div>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-left-right" viewBox="0 0 16 16">
                  <path fill-rule="evenodd" d="M1 11.5a.5.5 0 0 0 .5.5h11.793l-3.147 3.146a.5.5 0 0 0 .708.708l4-4a.5.5 0 0 0 0-.708l-4-4a.5.5 0 0 0-.708.708L13.293 11H1.5a.5.5 0 0 0-.5.5m14-7a.5.5 0 0 1-.5.5H2.707l3.147 3.146a.5.5 0 1 1-.708.708l-4-4a.5.5 0 0 1 0-.708l4-4a.5.5 0 1 1 .708.708L2.707 4H14.5a.5.5 0 0 1 .5.5"/>
                </svg>
                Process state:
                <strong tal:content="view/get_status">Phase 0</strong>

                <div class="phase-selector" tal:condition="python: not(view.read_only_access)">
                  <select onchange="javascript:this.form.submit()" name="workflow_action" class="pat-select2" data-pat-select2="width:10em">
                    <option value=''>Choose action...</option>
                    <tal:rep repeat="trans view/get_transitions">
                      <option tal:content="trans/title" tal:attributes="value trans/id">Send to Phase 0</option>
                    </tal:rep>
                  </select>
                </div>
              </div>
            </form>
          </div>

          <table class="table as-table-overview table-striped">
            <thead>
              <tr>
                <th>Descriptor</th>
                <th>Article 9</th>
                <th>Article 8</th>
                <th>Article 10</th>
              </tr>
            </thead>
            <tbody>
              <tr tal:repeat="desc python: view.context.contentValues()">
                <th>
                  <span tal:content="python: view.descriptor_for_code(desc.id).title">D0</span>
                </th>
                <td tal:repeat="assessment python: view.get_articles(desc)">
                  <tal:block tal:define="css_class python:'assessment-status-colorbar btn btn-xs btn-' + view.get_status_color(assessment);
                      url assessment/absolute_url;
                      can_view_data python:view.can_view_assessment_data(assessment);
                      can_edit_data python:view.can_view_edit_assessment_data(assessment)">

                    <a tal:attributes="class css_class; href string:${url}/@@edit-assessment-data-2018;" tal:condition="can_edit_data">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pencil-square" viewBox="0 0 16 16">
                        <path d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z"/>
                        <path fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5z"/>
                      </svg>Assessment:
                      <span class="as-state-label" tal:content="python: view.get_status(assessment)">State</span>
                      <span title="New comments" class="has-new-comments glyphicon glyphicon-exclamation-sign" tal:condition="python: view.has_new_comments(assessment)"></span>
                    </a>
                    <div style='margin-top: 0.3rem'>
                      <a tal:attributes="href url" tal:condition="can_view_data" class="btn btn-xs btn-light">2018 Assessment</a>
                      <a tal:attributes="href string:${url}/@@view-report-data-2012;" class="btn btn-xs btn-light">2012 report</a>
                      <a tal:attributes="href string:${url}/@@view-report-data-2018;" class="btn btn-xs btn-light">2018 report</a>
                    </div>
                  </tal:block>
                </td>
              </tr>
            </tbody>
          </table>

        </div>
      </div>
    </div>

  </metal:block>
</html>
