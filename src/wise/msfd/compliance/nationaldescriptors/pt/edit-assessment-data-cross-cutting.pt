<div id="wise-compliance-form" class="full-width-marker" tal:define="can_comment view/can_comment; plone nocall:context/@@plone" tal:attributes="id view/form_id | string:wise-compliance-form">

  <div id="wise-compliance-form-top" tal:attributes="id view/form_id_top | string:wise-compliance-form-top">
    <metal:tabs metal:use-macro="context/wise-macros/macros/tabs"></metal:tabs>
  </div>

  <div class="wise-search-form-container" tal:attributes="id view/form_container_class | string:wise-search-form-container">

    <div class="left-side-formZ nat-edit-form">

      <h2 tal:content="structure view/title" class="report-title">Title here</h2>
      <!--<h4 class="process-phase-title">-->
      <!--Current phase: <span tal:content="python: view.current_phase[1]">Adequacy</span>-->
      <!--</h4>-->

      <div id="report-data-navigation" tal:condition="python: options.get('show_navigation') != False and view.can_view_assessment_data()">
        <div class="back-to-descr">
          <a href="./">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-left" viewBox="0 0 16 16">
              <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8"/>
            </svg>
            Back to descriptor assessment overview
          </a>
        </div>

        <div id="assessment-edit-infobox"></div>

        <div metal:use-macro="context/wise-macros/macros/nat-desc-report-nav-cross-cutting"></div>
      </div>

      <div id="comp-national-descriptor">

        <div class="modal" id="question-intro" tabindex="-1" role="dialog">
          <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
              <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                  <span aria-hidden="true">&times;</span>
                </button>
                <h3 class="modal-title">
                  <span class='modal-question-id'>Question ID</span>: Question guidance</h3>
              </div>
              <div class="modal-body">Text here</div>
              <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
              </div>
            </div>
          </div>
        </div>

        <div id="edit-comment-modal" class="modal" tabindex="-1" role="dialog">
          <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
              <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                  <span aria-hidden="true">&times;</span>
                </button>
                <h3 class="modal-title">Edit comment</h3>
              </div>
              <div class="modal-body">
                <h4 class="modal-comment-header">Original comment</h4>
                <div class="modal-comment-section" id="comment-original-text">Original comment</div>
                <form id="form-edit-comment">
                  <input id="comm_original" type="hidden" name="comm_original" tal:attributes="value python:'' or None" />
                  <input id="comm_name" type="hidden" name="comm_name" tal:attributes="value python:'' or None" />
                  <input id="comm_time" type="hidden" name="comm_time" tal:attributes="value python:'' or None" />
                  <input id="q" type="hidden" name="q" tal:attributes="value python:'' or None" />
                  <input id="thread_id" type="hidden" name="thread_id" tal:attributes="value python:'' or None" />
                  <div class="form-group" tal:attributes="portal_url context/portal_url">
                    <h4 class="modal-comment-header">New comment</h4>
                    <textarea class="form-control" style="height: 10em;" type="text" id="new_comment" name="new_comment"></textarea>
                    <div style="padding-top: 1rem;">
                      <input class="submitComment btn btn-primary btn-s" type="submit" value="Save" />
                    </div>
                  </div>
                </form>
              </div>
            </div>
          </div>
        </div>

        <metal:form use-macro="context/@@ploneform-macros/titlelessform">

          <metal:fields fill-slot="fields">
            <tal:rep tal:repeat='subform view/subforms'>

              <h3 tal:condition="python: getattr(subform, '_q_heading', '')" tal:content="python: subform._q_heading">Section B - Update of first cycle</h3>

              <div class="subform" tal:define="disabled python:subform._disabled and ' disabled' or '';
                  source_info python: subform._source_info;
                  question_guidance python: view.get_question_guidance(subform)" tal:attributes="class string:subform $disabled">

                <div class="body">
                  <div class="left">
                    <div class="subform-title">
                      <div class="question-title">
                        <i tal:condition="question_guidance" tal:attributes="data-text question_guidance;
                            data-questionid python: subform._question_id" title="Show question guidance" class="question-intro glyphicon glyphicon-question-sign" data-toggle="modal" data-target="#question-intro">
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-question-circle-fill" viewBox="0 0 16 16">
                            <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0M5.496 6.033h.825c.138 0 .248-.113.266-.25.09-.656.54-1.134 1.342-1.134.686 0 1.314.343 1.314 1.168 0 .635-.374.927-.965 1.371-.673.489-1.206 1.06-1.168 1.987l.003.217a.25.25 0 0 0 .25.246h.811a.25.25 0 0 0 .25-.25v-.105c0-.718.273-.927 1.01-1.486.609-.463 1.244-.977 1.244-2.056 0-1.511-1.276-2.241-2.673-2.241-1.267 0-2.655.59-2.75 2.286a.237.237 0 0 0 .241.247m2.325 6.443c.61 0 1.029-.394 1.029-.927 0-.552-.42-.94-1.029-.94-.584 0-1.009.388-1.009.94 0 .533.425.927 1.01.927z"/>
                          </svg>
                        </i>
                        <div tal:content="subform/title">Question here</div>
                      </div>
                      <div style="display: flex;
                          float: right;
                          flex-direction: column;
                          align-items: flex-end;
                          justify-content: center;">
                        <span style="float:right;" tal:define="last_change python: view.format_last_change(subform._last_update)" class="pat-tooltip" tal:attributes="titleZ python: ''; title python: last_change">
                          <span tal:content="string:Last change">Last change</span>
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-calendar-check" viewBox="0 0 16 16">
                            <path d="M10.854 7.146a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708 0l-1.5-1.5a.5.5 0 1 1 .708-.708L7.5 9.793l2.646-2.647a.5.5 0 0 1 .708 0"/>
                            <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5M1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4z"/>
                          </svg>
                        </span>
                        <span tal:condition="source_info" style="float:right;" class="pat-tooltip" tal:attributes="titleZ python: ''; title source_info">
                          <span tal:content="string:Source info">Source info</span>
                          <i class="glyphicon glyphicon-info-sign">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-info-circle-fill" viewBox="0 0 16 16">
                              <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16m.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.47l-.451-.081.082-.381 2.29-.287zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2"/>
                            </svg>
                          </i>
                        </span>
                      </div>
                    </div>
                    <div class="fields-container">
                      <div tal:repeat="fieldname subform/fields" class="fields-container-row">
                        <tal:def define="widget python: view.widgets[fieldname]">

                          <div class="field" tal:define="error widget/error;
                            hidden python:widget.mode == 'hidden';
                            element nocall: widget/field/_element | nothing;" tal:attributes="class python:'field' + (error and ' error' or '')">

                            <span class="fieldRequired" title="Required" tal:condition="python:widget.required and not hidden" i18n:translate="label_required" i18n:attributes="title title_required;">
                              (Required)
                            </span>

                            <div class="widget">
                              <div>
                                <label for="" tal:condition="not:hidden" class="pat-tooltip" tal:attributes="for widget/id;
                                  titleZ python: element and element.title or '';
                                  title python: element and view.get_translated(element.definition) or ''">
                                  <span i18n:translate="" tal:content="widget/label">label</span>
                                  <!-- <span tal:condition="element" class="glyphicon glyphicon-question-sign"></span> -->
                                </label>
                              </div>
                              <div class="assessment-form-input">
                                <input type="text" tal:replace="structure widget/render" />
                              </div>
                            </div>

                            <div class="formHelp" tal:define="description widget/field/description" i18n:translate="" tal:content="description" tal:condition="python:description and not hidden">
                              field description
                            </div>

                            <div tal:condition="error" tal:content="structure error/render">
                              Error
                            </div>
                          </div>

                        </tal:def>
                      </div>
                    </div>
                  </div>

                  <div class="right discussion disc-tl" tal:define="question_id subform/_question/id | subform/_question_id | string:summary">
                    <div class="comments-header">
                      <i class="comm-hide glyphicon glyphicon-plus-sign" title="Show all comments"></i>
                    </div>
                    <div class="comments" tal:attributes="data-question-id question_id; data-thread-id string:tl">
                    </div>

                    <div tal:condition="python: can_comment" class="textline">
                      <textarea name="comment-text" placeholder="Write a comment..."></textarea>
                      <button class="btn btn-primary">
                        Post
                      </button>
                    </div>
                  </div>

                </div>
              </div>
            </tal:rep>
          </metal:fields>

          <metal:slot fill-slot="actions">
            <div tal:condition="python: not(view.read_only_access)" class="form-right-side">
              <metal:block use-macro="context/@@ploneform-macros/actions" />
            </div>
          </metal:slot>

        </metal:form>
      </div>
    </div>
  </div>
</div>
