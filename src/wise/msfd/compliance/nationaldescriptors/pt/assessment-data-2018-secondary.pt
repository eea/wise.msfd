<div id="container-assessment-data-2018" tal:define="assessment options/assessment;
    score_2012 python: int(options['score_2012']);
    conclusion_2012 python: '{} ({})'.format(options['conclusion_2012'], score_2012)">
  <div class="table-wrap">
    <table class="table table-condensed assessment-data-table">
      <tbody>

        <tr>
          <th class="fixed-left as-question as-header">Question / assessed elements</th>
          <th class="fixed-left as-header" tal:condition="not: assessment/gescomponents"></th>
          <th colspan="2" class="fixed-center as-ges-component as-header"></th>
          <th class="fixed-right as-header">Conclusion</th>
          <th class="fixed-right as-th-score as-header">Score</th>
        </tr>

        <tal:rep tal:repeat="row assessment/answers">
          <tr>
            <th class="fixed-left">
              <div class="q-wrap">
                <div class="q-id" tal:content="python: row.question.split(':')[0]">Question Id</div>
                <div class="q-title" tal:content="python: row.question.split(':', 1)[1]">Question text</div>
              </div>
            </th>
            <td colspan="2" class="fixed-center">
              <tal:rep tal:repeat="value row/values">
                <div tal:attributes="class python: 'gescomp as-value as-value-{}'.format(value[1]);">

                  <label for="" data-trigger="hover" data-html="true" tal:attributes="
                    title python: value[0];
                    data-content python: value[2]">
                    <span tal:content="python: value[2]">D0C0</span>
                  </label>

                </div>
              </tal:rep>
              <div class="assessment-summary" tal:content="row/summary">Summary</div>
            </td>

            <td tal:attributes="class python: 'fixed-right as-value as-value-{}'.format(row.conclusion_color)" colspan="1">
              <strong tal:condition="python: False" tal:content="python: '{} ({}%)'.format(row.conclusion, getattr(row.score, 'percentage'))">Very poor</strong>
              <strong tal:condition="row/score" tal:content="row/conclusion">Very poor</strong>
            </td>

            <td tal:attributes="class python: 'fixed-right'">
              <span tal:condition="row/score" class="score pat-tooltip glyphicon glyphicon-info-sign"  tal:attributes="titleZ python: 'Score calculation algorithm';
                    title python: getattr(row.score, 'score_tooltip', '');">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-info-circle-fill" viewBox="0 0 16 16">
                  <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16m.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.47l-.451-.081.082-.381 2.29-.287zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2"/>
                </svg>
              </span>
              <span tal:condition="python: not row.score" class="score pat-tooltip glyphicon glyphicon-exclamation-sign" tal:attributes="titleZ python: 'Score calculation algorithm';
                    title python: 'Score is calculated after all answers are filled in.';">
              </span>
              <span tal:content="python: getattr(row.score, 'final_score', 0)">0</span>
            </td>

          </tr>
        </tal:rep>


        <tr id="asssessment-overview-form-comments">
          <th class="fixed-left">Assessment summary, progress assessment and recommendations</th>

          <td class="fixed-center subform">
            <div class="form-assessment-summary">
              <div tal:replace="structure context/@@view-assessment-summary"></div>
            </div>
          </td>

          <td class="overall-headers fixed-right">
            <div class="as-value">2018 Overall </div>
          </td>
          <td class="overall-values fixed-right" tal:define="phase_score python: assessment.phase_overall_scores">
            <div tal:attributes="class python: 'as-value as-value-{}'.format(assessment.overall_conclusion_color)">
              <strong tal:content="python: '{} ({})'.format(
                assessment.overall_conclusion[1], assessment.overall_conclusion[0])">Very poor (1)</strong>
            </div>
          </td>

          <td class="overall-values fixed-right" tal:define="phase_score python: assessment.phase_overall_scores">
            <div tal:attributes="class python: 'as-value as-value-{}'.format(assessment.overall_conclusion_color)">
              <span class="score pat-tooltip glyphicon glyphicon-info-sign" tal:attributes="titleZ python: 'Score calculation algorithm';
                    title python: phase_score.score_tooltip_overall_secondary(view.article);">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-info-circle-fill" viewBox="0 0 16 16">
                  <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16m.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.47l-.451-.081.082-.381 2.29-.287zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2"/>
                </svg>
              </span>
              <span tal:content="assessment/overall_score">56.8</span>
            </div>
          </td>
        </tr>

      </tbody>
    </table>
  </div>

</div>
