<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en"
  xmlns:tal="http://xml.zope.org/namespaces/tal"
  xmlns:metal="http://xml.zope.org/namespaces/metal"
  xmlns:i18n="http://xml.zope.org/namespaces/i18n" lang="en" metal:use-macro="context/main_template/macros/master" i18n:domain="eea">

  <metal:block fill-slot="main">

    <div id="layout-contents" tal:define="text context/text | nothing">
      <div id="wise-search-form" class="full-width-marker">
        <div id="wise-search-form-topZ">
          <metal:tabs metal:use-macro="context/wise-macros/macros/tabs"></metal:tabs>
        </div>

        <div class="start-page-content left-side-formZ" tal:define="year_2018 python: view.get_report_year('2018');
                year_2012 python: view.get_report_year('2012')">

          <div metal:use-macro="context/global_statusmessage/macros/portal_message">
            Status message
          </div>

          <h1 class="report-title" tal:content="structure view/title">Assessment</h1>
          <h4 class="process-phase-title">
            Current phase: <span tal:content="python: view.current_phase[1]">Adequacy</span>
          </h4>

          <div id="report-data-navigation">
            <div class="nda-link">
              <a href="/marine/assessment-module/national-descriptors-assessments/${view/country_code/lower}/assessments">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-left" viewBox="0 0 16 16">
                  <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8"/>
                </svg>
                Go to Assessments page
              </a>
            </div>

            <div id="assessment-edit-infobox"></div>

            <div metal:use-macro="context/wise-macros/macros/nat-desc-report-nav"></div>
          </div>
          <div class="scroll-to-top">
            <button title="Scroll to top" class="scroll-button">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="scroll-icon bi bi-chevron-up" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M7.646 4.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1-.708.708L8 5.707l-5.646 5.647a.5.5 0 0 1-.708-.708z"/>
              </svg>
            </button>
          </div>

          <div id="nat-desc-art-menu">
            <ul>
              <li>
                <a tal:attributes="href python: context.absolute_url() + '/@@edit-assessment-data-{}'.format(year_2018)" target="_blank">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pencil-square" viewBox="0 0 16 16">
                    <path d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z"/>
                    <path fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5z"/>
                  </svg> Assessment
                </a>
                <a tal:attributes="href python: context.absolute_url() + '/@@view-edit-history'" class="glyphicon glyphicon-th pat-plone-modal" data-pat-plone-modal="height: 600px; content:#edit-history; width: 80%"></a>
              </li>
              <li>
                <a tal:attributes="href python: context.absolute_url() + '/@@view-report-data-' + year_2018" target="_blank">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-table" viewBox="0 0 16 16">
                    <path d="M0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2zm15 2h-4v3h4zm0 4h-4v3h4zm0 4h-4v3h3a1 1 0 0 0 1-1zm-5 3v-3H6v3zm-5 0v-3H1v2a1 1 0 0 0 1 1zm-4-4h4V8H1zm0-4h4V4H1zm5-3v3h4V4zm4 4H6v3h4z"/>
                  </svg>
                  <span tal:content="year_2018">2018</span> Report
                </a>
              </li>
              <li>
                <a tal:attributes="href python: context.absolute_url() + '/@@view-report-data-' + year_2012" target="_blank">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-table" viewBox="0 0 16 16">
                    <path d="M0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2zm15 2h-4v3h4zm0 4h-4v3h4zm0 4h-4v3h3a1 1 0 0 0 1-1zm-5 3v-3H6v3zm-5 0v-3H1v2a1 1 0 0 0 1 1zm-4-4h4V8H1zm0-4h4V4H1zm5-3v3h4V4zm4 4H6v3h4z"/>
                  </svg>
                  <span tal:content="year_2012">2012</span> Report
                </a>
              </li>
              <li class="process-state" style="display:flex; align-items: center">
                <form method="GET" tal:attributes="action python: context.absolute_url() + '/content_status_modify'">
                  <div>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-left-right" viewBox="0 0 16 16">
                      <path fill-rule="evenodd" d="M1 11.5a.5.5 0 0 0 .5.5h11.793l-3.147 3.146a.5.5 0 0 0 .708.708l4-4a.5.5 0 0 0 0-.708l-4-4a.5.5 0 0 0-.708.708L13.293 11H1.5a.5.5 0 0 0-.5.5m14-7a.5.5 0 0 1-.5.5H2.707l3.147 3.146a.5.5 0 1 1-.708.708l-4-4a.5.5 0 0 1 0-.708l4-4a.5.5 0 1 1 .708.708L2.707 4H14.5a.5.5 0 0 1 .5.5"/>
                    </svg>
                    Process state:
                    <strong tal:content="view/get_status">Phase 0</strong>
                    <select tal:condition="python: view.can_change_process_state()" onchange="javascript:this.form.submit()" name="workflow_action" class="pat-select2" data-pat-select2="width:10em">
                      <option value=''>Choose action...</option>
                      <tal:rep repeat="trans view/get_transitions">
                        <option tal:content="trans/title" tal:attributes="value trans/id">Send to Phase 0</option>
                      </tal:rep>
                    </select>
                  </div>
                </form>
                <a tal:attributes="href python: context.absolute_url() + '/@@historyview'" class="link-overlay contentHistory glyphicon glyphicon-time" id="content-history" style="margin-left: 2rem">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-clock-history" viewBox="0 0 16 16">
                    <path d="M8.515 1.019A7 7 0 0 0 8 1V0a8 8 0 0 1 .589.022zm2.004.45a7 7 0 0 0-.985-.299l.219-.976q.576.129 1.126.342zm1.37.71a7 7 0 0 0-.439-.27l.493-.87a8 8 0 0 1 .979.654l-.615.789a7 7 0 0 0-.418-.302zm1.834 1.79a7 7 0 0 0-.653-.796l.724-.69q.406.429.747.91zm.744 1.352a7 7 0 0 0-.214-.468l.893-.45a8 8 0 0 1 .45 1.088l-.95.313a7 7 0 0 0-.179-.483m.53 2.507a7 7 0 0 0-.1-1.025l.985-.17q.1.58.116 1.17zm-.131 1.538q.05-.254.081-.51l.993.123a8 8 0 0 1-.23 1.155l-.964-.267q.069-.247.12-.501m-.952 2.379q.276-.436.486-.908l.914.405q-.24.54-.555 1.038zm-.964 1.205q.183-.183.35-.378l.758.653a8 8 0 0 1-.401.432z"/>
                    <path d="M8 1a7 7 0 1 0 4.95 11.95l.707.707A8.001 8.001 0 1 1 8 0z"/>
                    <path d="M7.5 3a.5.5 0 0 1 .5.5v5.21l3.248 1.856a.5.5 0 0 1-.496.868l-3.5-2A.5.5 0 0 1 7 9V3.5a.5.5 0 0 1 .5-.5"/>
                  </svg>
                </a>
              </li>
            </ul>
          </div>

          <div class="asts-header-data">
            <h3 id="assessment-2018" tal:content="python: '{} Assessment'.format(year_2018)">2018 Assessment</h3>
            <div class="ast-header-data">
              <div tal:replace="structure view/assessment_header_2018_html"></div>
              <div tal:replace="structure view/assessment_data_2018_html"></div>
            </div>

            <!-- <h3 id="assessment-2012">2012 Assessment</h3>
            <div class="ast-header-data">
              <div tal:replace="structure view/assessment_header_2012"></div>
              <div tal:replace="structure view/assessment_data_2012"></div>
            </div> -->
          </div>

        </div>
      </div>
    </div>

  </metal:block>
</html>
