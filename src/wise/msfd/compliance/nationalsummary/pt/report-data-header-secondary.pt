<div tal:attributes="id python: getattr(view, '_id', '')" class="row">
  <div class="col-md-12">

    <div metal:use-macro="context/global_statusmessage/macros/portal_message">
      Status message
    </div>

    <h3 class="report-title" tal:content="structure options/title">201X Member State Report</h3>

    <div id="report-data-navigation" tal:condition="python: options.get('show_navigation') != False and view.can_view_assessment_data()">
      <div class="back-to-art">
        <a href="/marine/assessment-module/national-descriptors-assessments/${view/country_code/lower}/reports">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-left" viewBox="0 0 16 16">
            <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8"/>
          </svg>
          Go to Reports page
        </a>
      </div>
    </div>
    <div class="scroll-to-top">
      <button title="Scroll to top" class="scroll-button">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="scroll-icon bi bi-chevron-up" viewBox="0 0 16 16">
          <path fill-rule="evenodd" d="M7.646 4.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1-.708.708L8 5.707l-5.646 5.647a.5.5 0 0 1-.708-.708z"/>
        </svg>
      </button>
    </div>

    <table class="table table-bordered table-striped table-condensed" style="margin-bottom: 40px;">
      <tr>
        <td style="width: 200px;">MSFD Article</td>
        <td tal:content="options/article_name"/>
      </tr>
      <tr tal:condition="options/report_date">
        <td>Report date</td>
        <td tal:content="options/report_date"/>
      </tr>
      <tr>
        <td>Access reports</td>
        <td>
          <a tal:attributes="href python: view._compliance_folder.absolute_url() + '/national-descriptors-assessments/{}/{}/@@view-report-data-2018'.format(view.country_code.lower(), view.article.lower())" target="_blank">View all reports</a>
        </td>
      </tr>
    </table>
  </div>
</div>
